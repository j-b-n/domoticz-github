# GitHub Stats Domoticz Plugin — credentials template
# Copy this file to .env and fill in your token.

# -----------------------------------------------
# Required
# -----------------------------------------------

# GitHub Personal Access Token (PAT)
# Fine-grained token: needs Metadata: read (implicit) + Plan: read (Copilot billing)
# Add Contents: read if you want private repositories to appear.
# Classic token: no scopes needed for public data; add "repo" for private repos.
# Create one at: https://github.com/settings/tokens?type=beta
GITHUB_PAT=ghp_YOUR_TOKEN_HERE

# -----------------------------------------------
# Optional
# -----------------------------------------------

# Override the monthly Copilot premium request quota used for the % bar.
# Defaults to 150 (GitHub Copilot Individual included quota).
# GITHUB_COPILOT_MONTHLY_QUOTA=150
